# Copy to .env in this directory (or keep using ingestion/phase-4-6-chroma/.env; Phase 5 now loads that file too).
# Use the same Chroma Cloud tenant/database for Phase 4.6 (ingest) and Phase 5 (retrieval).

CHROMA_CLOUD_TENANT=
CHROMA_CLOUD_DATABASE=
CHROMA_API_KEY=

# Optional: default collection (must match 4.6)
# CHROMA_COLLECTION_NAME=mf_faq_groww_metrics
# RETRIEVE_COLLECTION_NAME=mf_faq_groww_metrics

# Ingest: leave unset to use Chroma Cloud when tenant+database+key are set
# CHROMA_USE_PERSISTENT=0
